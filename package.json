{
  "name": "codexcc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CodexCC is a Codex-based general-agent harness that mimics Claude Code-style session structure.",
  "bin": {
    "codexcc": "./dist/cli.js",
    "codexcc-bridge": "./dist/bridge.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:bridge": "tsx src/bridge.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "node-pty": "^1.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
